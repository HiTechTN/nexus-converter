{
  "name": "@workspace/nexus-desktop",
  "version": "1.0.0",
  "description": "NEXUS CONVERTER — Desktop Application (Electron)",
  "author": "HiTechTN <hitechtn@users.noreply.github.com>",
  "homepage": "https://github.com/HiTechTN/nexus-converter",
  "license": "MIT",
  "repository": "github:HiTechTN/nexus-converter",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build": "pnpm run build:electron",
    "package:linux": "pnpm run build && electron-builder --linux --config electron-builder.yml",
    "package:win": "pnpm run build && electron-builder --win --config electron-builder.yml",
    "package:all": "pnpm run build && electron-builder --linux --win --config electron-builder.yml",
    "clean": "rm -rf dist-electron dist release"
  },
  "dependencies": {
    "electron-store": "^8.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "electron": "^30.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.4.0"
  }
}
